        {
          "datasource": {
            "type": "influxdb",
            "uid": "InfluxDB_Energy"
          },
          "query": "import \"strings\"\n\ndata = from(bucket: \"energy\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"emeter\")\n  |> filter(fn: (r) => r[\"_field\"] == \"PowerMW\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ \n      r with \n      _value: float(v: r._value) / 1000.0\n    }))\n\ndata\n  |> map(fn: (r) => ({ \n      r with \n      _field: r.alias + \" (\" + strings.substring(v: r.device, start: 37, end: 40) + \")\"\n    }))\n  |> keep(columns: [\"_time\", \"_value\", \"_field\"])\n  |> yield(name: \"individual_devices\")\n\ndata\n  |> group(columns: [\"_time\"]) \n  |> sum()\n  |> group()   \n  |> map(fn: (r) => ({ r with _field: \"TOTAL SYSTEM DRAW\" }))\n  |> keep(columns: [\"_time\", \"_value\", \"_field\"])\n  |> yield(name: \"total_draw\")",
          "refId": "A"
        }
      ],
      "title": "Watt of Power",
      "type": "timeseries"
