          "query": "data = from(bucket: \"energy\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"emeter\")\n  |> filter(fn: (r) => r[\"_field\"] == \"VoltageMV\")\n  |> map(fn: (r) => ({ r with _value: float(v: r._value) / 1000.0 }))\n  |> group() \n\ndata |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> map(fn: (r) => ({ _time: r._time, Average: r._value })) |> yield(name: \"avg\")\ndata |> aggregateWindow(every: v.windowPeriod, fn: min, createEmpty: false)  |> map(fn: (r) => ({ _time: r._time, Min: r._value }))     |> yield(name: \"min\")\ndata |> aggregateWindow(every: v.windowPeriod, fn: max, createEmpty: false)  |> map(fn: (r) => ({ _time: r._time, Max: r._value }))     |> yield(name: \"max\")",
          "refId": "A"
        }
      ],
